# ─────────────────────────────────────────────
# SENTINEL — Environment Variables
# Copy to .env.local and fill in your keys
# ─────────────────────────────────────────────

# REQUIRED: Groq AI (free tier available)
# Get at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Civic AI Governance
# Without this, Civic falls back to local execution (still works)
# Get at: https://app.civic.com
CIVIC_API_KEY=
CIVIC_MCP_URL=https://app.civic.com/hub/mcp?accountId=YOUR_ACCOUNT_ID&profile=default

# Deployment URL — needed for sandbox scanner to call back to itself
# On Vercel this is set automatically. For local dev: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Sandbox WebSocket server URL (the separate sandbox service)
# Local dev: ws://localhost:4000
# Render: wss://sentinel-sandbox.onrender.com
NEXT_PUBLIC_SANDBOX_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SANDBOX_URL=http://localhost:4000
